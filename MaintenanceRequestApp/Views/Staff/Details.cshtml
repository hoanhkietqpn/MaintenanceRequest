@model MaintenanceRequestApp.Models.RequestMaintenance
@{
    ViewData["Title"] = "Chi tiết Phiếu Bảo trì";

    string statusLabel = Model.Status switch
    {
        1 => "Khởi tạo",
        2 => "Đã Phê duyệt",
        3 => "Đang sửa chữa",
        4 => "Hoàn thành",
        5 => "Đã Hủy",
        _ => "Không xác định"
    };
    string statusClass = Model.Status switch
    {
        1 => "bg-secondary",
        2 => "bg-info text-dark",
        3 => "bg-warning text-dark",
        4 => "bg-success",
        5 => "bg-danger",
        _ => "bg-light text-dark"
    };
}

<!-- ── Toast Notification ── -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="position-fixed top-0 end-0 p-3" style="z-index:9999">
        <div id="liveToast" class="toast align-items-center text-white bg-success border-0 show">
            <div class="d-flex">
                <div class="toast-body fw-bold">@TempData["SuccessMessage"]</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>
}

<!-- ── Page Header ── -->
<div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
    <div>
        <h5 class="fw-bold mb-0"><i class="bi bi-file-earmark-text me-2 text-vjaa"></i>Chi tiết Phiếu Bảo trì</h5>
        <small class="text-muted d-none d-md-inline">Mã: <code class="small">@Model.Id</code></small>
    </div>
    <div class="d-flex gap-2 align-items-center flex-wrap">
        <span class="badge @statusClass fs-6 px-3 py-2">@statusLabel</span>
        <a href="javascript:history.back()" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Trở về
        </a>
    </div>
</div>

<!-- ══════════════════════════════════════════ -->
<!-- TWO-COLUMN RESPONSIVE LAYOUT              -->
<!-- ══════════════════════════════════════════ -->
<div class="row g-3">

    <!-- ── LEFT COLUMN: Main Content ── -->
    <div class="col-12 col-lg-8 mb-4">

        <!-- SECTION A: Thông tin chung -->
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-header bg-vjaa text-white fw-bold py-2">
                <i class="bi bi-info-circle me-2"></i>A. Thông tin chung
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-12 col-sm-6">
                        <div class="text-muted small fw-bold text-uppercase mb-1">Thiết bị hư hỏng</div>
                        <div class="fw-bold">@Model.EquipmentDamged</div>
                    </div>
                    <div class="col-12 col-sm-6">
                        <div class="text-muted small fw-bold text-uppercase mb-1">Vị trí</div>
                        <div><i class="bi bi-geo-alt text-danger me-1"></i>@Model.Location</div>
                    </div>
                    <div class="col-12 col-sm-6">
                        <div class="text-muted small fw-bold text-uppercase mb-1">Người báo cáo</div>
                        <div>@Model.FullName</div>
                        <div class="small text-muted">@Model.Email</div>
                    </div>
                    <div class="col-12 col-sm-6">
                        <div class="text-muted small fw-bold text-uppercase mb-1">Mức độ khẩn cấp</div>
                        @if (!string.IsNullOrEmpty(Model.Urgency) && Model.Urgency != "Không xác định / Not specified")
                        { <span class="badge bg-warning text-dark">@Model.Urgency</span> }
                        else { <span class="text-muted small">Không xác định</span> }
                    </div>
                    <div class="col-12">
                        <div class="text-muted small fw-bold text-uppercase mb-1">Mô tả sự cố</div>
                        <div class="border rounded p-3 bg-light small">@Model.Description</div>
                    </div>
                    <div class="col-6 col-sm-4">
                        <div class="text-muted small fw-bold text-uppercase mb-1">Ngày tạo</div>
                        <div class="small">@Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                    <div class="col-6 col-sm-4">
                        <div class="text-muted small fw-bold text-uppercase mb-1">Bắt đầu sửa</div>
                        <div class="small">@(Model.StartTime.HasValue ? Model.StartTime.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm") : "—")</div>
                    </div>
                    <div class="col-6 col-sm-4">
                        <div class="text-muted small fw-bold text-uppercase mb-1">Hoàn thành</div>
                        <div class="small @(Model.EndTime.HasValue ? "text-success fw-bold" : "")">
                            @(Model.EndTime.HasValue ? Model.EndTime.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm") : "—")
                        </div>
                    </div>
                </div>

                @if (Model.Assignments != null && Model.Assignments.Any())
                {
                    <hr class="my-2" />
                    <div class="text-muted small fw-bold text-uppercase mb-1">Nhân viên phụ trách</div>
                    <div class="d-flex flex-wrap gap-2 mt-1">
                        @foreach (var a in Model.Assignments)
                        {
                            <span class="badge bg-info text-dark"><i class="bi bi-person me-1"></i>@(a.User?.FirstName + " " + a.User?.LastName)</span>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- SECTION B: Hình ảnh gốc -->
        @if (Model.Medias != null && Model.Medias.Any())
        {
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-header bg-white fw-bold border-bottom py-2">
                    <i class="bi bi-images me-2 text-primary"></i>B. Hình ảnh báo cáo lỗi
                    <span class="badge bg-primary ms-2">@Model.Medias.Count ảnh</span>
                </div>
                <div class="card-body">
                    <div class="row g-2">
                        @foreach (var media in Model.Medias)
                        {
                            <div class="col-6 col-sm-4 col-md-3">
                                <a href="#" data-bs-toggle="modal" data-bs-target="#imgModal-@media.MediaId">
                                    <img src="@media.FilePath" class="img-fluid rounded border" style="width:100%;height:100px;object-fit:cover;" alt="Ảnh lỗi" />
                                </a>
                            </div>
                            <div class="modal fade" id="imgModal-@media.MediaId" tabindex="-1">
                                <div class="modal-dialog modal-lg modal-dialog-centered">
                                    <div class="modal-content bg-dark border-0">
                                        <div class="modal-header border-0 pb-0">
                                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body text-center p-2">
                                            <img src="@media.FilePath" class="img-fluid rounded" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- SECTION C: Timeline Báo cáo tiến độ -->
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-header bg-white fw-bold border-bottom py-2">
                <i class="bi bi-chat-left-text me-2 text-vjaa"></i>C. Lịch sử xử lý &amp; Báo cáo
                @if (Model.MaintenanceNotes != null)
                { <span class="badge bg-vjaa ms-2">@Model.MaintenanceNotes.Count ghi chú</span> }
            </div>
            <div class="card-body">
                @if (Model.MaintenanceNotes == null || !Model.MaintenanceNotes.Any())
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-chat-square-dots fs-2 d-block mb-2"></i>
                        Chưa có báo cáo hoặc ghi chú nào.
                    </div>
                }
                else
                {
                    @foreach (var note in Model.MaintenanceNotes.OrderBy(n => n.CreatedAt))
                    {
                        <div class="d-flex mb-3">
                            <div class="flex-shrink-0 me-2">
                                <div class="rounded-circle bg-vjaa text-white d-flex align-items-center justify-content-center" style="width:36px;height:36px;font-size:1rem;">
                                    <i class="bi bi-person-fill"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1">
                                <div class="card border-0 shadow-sm timeline-card">
                                    <div class="card-header bg-light d-flex justify-content-between align-items-start py-2 flex-wrap gap-1">
                                        <span class="fw-bold small">
                                            @if (note.User != null)
                                            {
                                                @(note.User.FirstName + " " + note.User.LastName)
                                                <span class="badge bg-secondary fw-normal ms-1">@note.User.Role</span>
                                            }
                                            else { <span class="text-muted">Hệ thống</span> }
                                        </span>
                                        <small class="text-muted"><i class="bi bi-clock me-1"></i>@note.CreatedAt.ToLocalTime().ToString("HH:mm dd/MM")</small>
                                    </div>
                                    <div class="card-body py-2">
                                        <p class="mb-1 small">@note.NoteContent</p>
                                        @if (!string.IsNullOrEmpty(note.ImagePath))
                                        {
                                            <a href="#" data-bs-toggle="modal" data-bs-target="#noteImg-@note.NoteId">
                                                <img src="@note.ImagePath" class="img-fluid rounded border mt-2" style="max-height:160px;object-fit:cover;" />
                                            </a>
                                            <div class="modal fade" id="noteImg-@note.NoteId" tabindex="-1">
                                                <div class="modal-dialog modal-lg modal-dialog-centered">
                                                    <div class="modal-content bg-dark border-0">
                                                        <div class="modal-header border-0 pb-0">
                                                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                                        </div>
                                                        <div class="modal-body text-center p-2">
                                                            <img src="@note.ImagePath" class="img-fluid rounded" />
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- SECTION D: Audit Log (Accordion) -->
        <div class="accordion mb-3" id="auditAccordion">
            <div class="accordion-item shadow-sm border-0">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed fw-bold py-2" type="button" data-bs-toggle="collapse" data-bs-target="#auditSection">
                        <i class="bi bi-journal-code me-2 text-secondary"></i>D. Nhật ký hệ thống
                        @if (Model.AuditLogs != null)
                        { <span class="badge bg-secondary ms-2">@Model.AuditLogs.Count</span> }
                    </button>
                </h2>
                <div id="auditSection" class="accordion-collapse collapse">
                    <div class="accordion-body p-0">
                        @if (Model.AuditLogs == null || !Model.AuditLogs.Any())
                        { <div class="text-center py-3 text-muted small">Chưa có nhật ký nào.</div> }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm table-striped mb-0">
                                    <thead class="table-dark">
                                        <tr>
                                            <th style="width:130px">Thời gian</th>
                                            <th style="width:130px">Thực hiện bởi</th>
                                            <th>Hành động</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var log in Model.AuditLogs)
                                        {
                                            <tr>
                                                <td class="small text-muted">@log.Timestamp.ToLocalTime().ToString("HH:mm dd/MM")</td>
                                                <td class="small">@(log.UserId ?? "Hệ thống")</td>
                                                <td class="small">@log.Action</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

    </div><!-- /col-12 col-lg-8 -->


    <!-- ── RIGHT COLUMN: Bảng điều khiển (Sticky on Desktop) ── -->
    <div class="col-12 col-lg-4">
        <div class="sticky-sidebar">

            <!-- ─ STAFF: Gửi Báo cáo (Status==3) ─ -->
            @if (User.IsInRole("NhanVienKyThuat") && Model.Status == 3)
            {
                <div class="card shadow border-0 mb-3 border-start border-vjaa border-3">
                    <div class="card-header bg-white fw-bold py-2">
                        <i class="bi bi-send me-2 text-vjaa"></i>Gửi Báo cáo Tiến độ
                    </div>
                    <div class="card-body">
                        <form asp-controller="Staff" asp-action="AddReport" method="post" enctype="multipart/form-data">
                            <input type="hidden" name="requestId" value="@Model.Id" />
                            <div class="mb-2">
                                <label class="form-label small fw-bold">Nội dung báo cáo <span class="text-danger">*</span></label>
                                <textarea name="noteContent" class="form-control form-control-sm" rows="4"
                                          placeholder="Mô tả tiến độ công việc, vấn đề phát sinh..." required></textarea>
                            </div>
                            <div class="mb-2">
                                <label class="form-label small fw-bold"><i class="bi bi-image me-1"></i>Ảnh tiến độ (tối đa 1 ảnh, WebP)</label>
                                <input type="file" name="imageFile" class="form-control form-control-sm"
                                       accept="image/jpeg,image/png,image/jpg,image/webp" />
                                <div class="form-text">Ảnh sẽ được nén tự động sang WebP.</div>
                            </div>
                            <div class="form-check form-switch mb-3">
                                <input class="form-check-input" type="checkbox" name="sendEmail" value="true" id="sendEmailStaff" checked>
                                <label class="form-check-label small" for="sendEmailStaff">
                                    <i class="bi bi-envelope me-1 text-warning"></i>Gửi Email thông báo cho Quản lý
                                </label>
                            </div>
                            <button type="submit" class="btn btn-vjaa w-100 fw-bold">
                                <i class="bi bi-send me-2"></i>Gửi Báo cáo
                            </button>
                        </form>
                    </div>
                </div>
            }

            <!-- ─ STAFF: Đã hoàn thành (Status==4) ─ -->
            @if (User.IsInRole("NhanVienKyThuat") && Model.Status == 4)
            {
                <div class="card shadow border-0 mb-3 bg-success text-white">
                    <div class="card-body text-center py-4">
                        <i class="bi bi-patch-check-fill fs-1 d-block mb-2"></i>
                        <div class="fw-bold fs-5">Nhiệm vụ Hoàn thành!</div>
                        @if (Model.EndTime.HasValue)
                        { <small class="opacity-75">@Model.EndTime.Value.ToLocalTime().ToString("HH:mm dd/MM/yyyy")</small> }
                    </div>
                </div>
            }

            <!-- ─ STAFF: Chờ phê duyệt ─ -->
            @if (User.IsInRole("NhanVienKyThuat") && (Model.Status == 1 || Model.Status == 2))
            {
                <div class="card shadow-sm border-0 mb-3 border-start border-info border-3">
                    <div class="card-body text-center py-3">
                        <i class="bi bi-hourglass-split fs-2 text-info d-block mb-2"></i>
                        <div class="fw-bold text-info">@(Model.Status == 1 ? "Chờ Phê duyệt" : "Đã Phê duyệt — Chờ điều phối")</div>
                        <small class="text-muted">Bạn sẽ có thể gửi báo cáo khi nhiệm vụ bắt đầu.</small>
                    </div>
                </div>
            }

            <!-- ─ Hướng dẫn nhanh ─ -->
            <div class="card border-0 bg-light mb-3">
                <div class="card-body py-3">
                    <div class="small text-muted fw-bold mb-2"><i class="bi bi-lightbulb me-1 text-warning"></i>Hướng dẫn</div>
                    <ul class="list-unstyled small text-muted mb-0">
                        <li><i class="bi bi-dot"></i>Báo cáo thường xuyên để Quản lý cập nhật tiến độ.</li>
                        <li><i class="bi bi-dot"></i>Đính kèm ảnh giúp minh chứng tiến độ rõ ràng hơn.</li>
                        <li><i class="bi bi-dot"></i>Bật gửi Email để Quản lý được thông báo ngay.</li>
                    </ul>
                </div>
            </div>

        </div><!-- /sticky-sidebar -->
    </div><!-- /col-12 col-lg-4 -->

</div><!-- /row -->

<style>
    .bg-vjaa { background-color: #90c740 !important; }
    .text-vjaa { color: #90c740 !important; }
    .btn-vjaa { background-color: #90c740; border-color: #90c740; color: white; }
    .btn-vjaa:hover { background-color: #7ab535; border-color: #7ab535; color: white; }
    .border-vjaa { border-color: #90c740 !important; }
    .timeline-card { border-left: 3px solid #90c740 !important; }

    /* Sticky sidebar chỉ áp dụng trên màn hình lớn */
    @@media (min-width: 992px) {
        .sticky-sidebar {
            position: sticky;
            top: 20px;
        }
    }
</style>

@section Scripts {
    <script>
        // Auto-hide toast sau 4 giây
        $(document).ready(function () {
            var toastEl = document.getElementById('liveToast');
            if (toastEl) {
                setTimeout(function () {
                    bootstrap.Toast.getOrCreateInstance(toastEl).hide();
                }, 4000);
            }
        });
    </script>
}
