@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - Quản lý Sự cố và Bảo trì</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light">
    <div class="container d-flex justify-content-center align-items-center" style="min-height: 100vh;">
        <div class="card shadow p-4" style="width: 100%; max-width: 400px; border-radius: 12px; border: none;">
            <div class="text-center mb-4">
                <h4 class="text-primary fw-bold" style="color: #90c740 !important;">Hệ thống Bảo trì</h4>
                <p class="text-muted">Đăng nhập bằng tài khoản cục bộ / VIAA</p>
            </div>
            
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger py-2">
                    @Html.ValidationSummary(false, "", new { @class = "mb-0" })
                </div>
            }

            <form asp-controller="Auth" asp-action="Login" method="post">
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên đăng nhập</label>
                    <input type="text" name="username" class="form-control" placeholder="Nhập username" required />
                </div>
                <div class="mb-4">
                    <label class="form-label fw-bold">Mật khẩu</label>
                    <input type="password" name="password" class="form-control" placeholder="********" required />
                </div>
                <button type="submit" class="btn btn-primary w-100 py-2 fw-bold mb-3" style="background-color: #90c740; border-color: #90c740;">
                    Đăng nhập hệ thống
                </button>
            </form>
            
            <hr class="text-muted" />
            <div class="text-center">
                <a href="/Request/Create" class="text-decoration-none">
                    <i class="bi bi-pencil-square"></i> Tạo biểu mẫu báo cáo thiết bị hỏng
                </a>
            </div>
        </div>
    </div>
</body>
</html>
