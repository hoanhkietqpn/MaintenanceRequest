@model MaintenanceRequestApp.ViewModels.UserListViewModel
@{
    ViewData["Title"] = "Quản lý Người dùng";
}

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <h5 class="fw-bold mb-4 text-primary"><i class="bi bi-people me-2"></i> Danh sách Người dùng hệ thống</h5>
        
        <form method="get" class="mb-4 bg-light p-3 rounded rounded-3 border">
            <div class="row g-2 align-items-end">
                <div class="col-md-9">
                    <label class="form-label small fw-bold">Tìm kiếm</label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" name="searchTerm" value="@Model.SearchTerm" placeholder="Họ tên, Mã người dùng..." />
                    </div>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-sm btn-primary w-100"><i class="bi bi-funnel me-1"></i> Trích lọc</button>
                    <a href="/Admin/Users" class="btn btn-sm btn-outline-secondary w-100"><i class="bi bi-x-circle me-1"></i> Xóa</a>
                </div>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th class="text-nowrap">Tài khoản</th>
                        <th class="text-nowrap">Họ và tên</th>
                        <th class="text-nowrap">Email</th>
                        <th class="text-nowrap">Quyền hiện tại</th>
                        <th class="text-nowrap text-end">Cập nhật quyền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach(var item in Model.Users)
                    {
                        <tr>
                            <td class="fw-bold">@item.Username</td>
                            <td>@item.FirstName @item.LastName</td>
                            <td>@item.Email</td>
                            <td>
                                @if(item.Role == "Admin")
                                {
                                    <span class="badge bg-danger">Admin</span>
                                }
                                else if(item.Role == "QuanLyKyThuat")
                                {
                                    <span class="badge bg-primary">Trưởng nhóm</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Nhân viên</span>
                                }
                            </td>
                            <td class="text-end">
                                <form method="post" action="/Admin/ChangeRole" class="d-flex justify-content-end gap-1">
                                    <input type="hidden" name="userId" value="@item.UserId" />
                                    <select class="form-select form-select-sm w-auto" name="newRole">
                                        <option value="Admin" selected="@(item.Role == "Admin")">Admin</option>
                                        <option value="QuanLyKyThuat" selected="@(item.Role == "QuanLyKyThuat")">Trưởng nhóm</option>
                                        <option value="NhanVienKyThuat" selected="@(item.Role == "NhanVienKyThuat")">Nhân viên</option>
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-success"><i class="bi bi-check-lg"></i> Lưu</button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if(!Model.Users.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">Chưa có người dùng nào.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (Model.Users.TotalPages > 1)
        {
            var prevDisabled = !Model.Users.HasPreviousPage ? "disabled" : "";
            var nextDisabled = !Model.Users.HasNextPage ? "disabled" : "";

            <nav aria-label="Page navigation" class="mt-4">
                <ul class="pagination pagination-sm justify-content-center">
                    <li class="page-item @prevDisabled">
                        <a class="page-link" href="@Url.Action("Users", new { pageNumber = Model.Users.PageIndex - 1, searchTerm = Model.SearchTerm })">Trang trước</a>
                    </li>
                    <li class="page-item disabled">
                        <a class="page-link">Trang @Model.Users.PageIndex / @Model.Users.TotalPages</a>
                    </li>
                    <li class="page-item @nextDisabled">
                        <a class="page-link" href="@Url.Action("Users", new { pageNumber = Model.Users.PageIndex + 1, searchTerm = Model.SearchTerm })">Trang sau</a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>

<!-- Toast element cho Notification -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">
    <div id="actionToast" class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body">
                <i class="bi bi-check-circle me-2"></i> <span id="toastMessage">@TempData["ToastMessage"]</span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var message = "@TempData["ToastMessage"]";
            if(message && message.length > 0) {
                var toastEl = document.getElementById('actionToast');
                var toast = new bootstrap.Toast(toastEl);
                toast.show();
            }
        });
    </script>
}
