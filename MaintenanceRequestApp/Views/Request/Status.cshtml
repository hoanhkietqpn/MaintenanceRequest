@model MaintenanceRequestApp.Models.RequestMaintenance
@{
    Layout = "_LayoutPublic";
    ViewData["Title"] = "Trạng thái Yêu cầu";
}
<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card shadow-sm border-0 rounded-3 mb-4">
            <div class="card-header bg-primary text-white py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold"><i class="bi bi-info-circle me-2"></i>Chi tiết Sự cố / Incident Details</h5>
                <span class="badge bg-light text-primary fs-6">
                    @if(Model.Status == 1) { <span>Khởi tạo / Init</span> }
                    else if(Model.Status == 2) { <span>Đã duyệt / Approved</span> }
                    else if(Model.Status == 3) { <span>Đang sửa / In Progress</span> }
                    else if(Model.Status == 4) { <span>Hoàn thành / Completed</span> }
                    else if(Model.Status == 5) { <span>Đã Hủy / Canceled</span> }
                </span>
            </div>
            <div class="card-body p-4">
                <div class="row mb-3">
                    <div class="col-md-4 text-muted fw-bold">Mã / ID:</div>
                    <div class="col-md-8 text-break"><code>@Model.Id</code></div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-4 text-muted fw-bold">Thiết bị / Equipment:</div>
                    <div class="col-md-8">@Model.EquipmentDamged</div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-4 text-muted fw-bold">Vị trí / Location:</div>
                    <div class="col-md-8">@Model.Location</div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-4 text-muted fw-bold">Mô tả / Description:</div>
                    <div class="col-md-8">@Model.Description</div>
                </div>

                @if(Model.Medias != null && Model.Medias.Any())
                {
                    <div class="row mb-3">
                        <div class="col-md-4 text-muted fw-bold">Hình ảnh đính kèm:</div>
                        <div class="col-md-8 d-flex flex-wrap gap-2">
                            @foreach(var img in Model.Medias)
                            {
                                <img src="@img.FilePath" class="img-thumbnail rounded" style="width: 150px; height: 150px; object-fit: cover;" alt="Minh chứng" />
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- TIẾN ĐỘ XỬ LÝ -->
        <h5 class="fw-bold mb-3 text-primary mt-4"><i class="bi bi-bar-chart-steps me-1"></i> Tiến độ Xử lý / Progress</h5>
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                @{
                    int progress = 25;
                    if (Model.Status == 2) progress = 50;
                    if (Model.Status == 3) progress = 75;
                    if (Model.Status == 4) progress = 100;
                    if (Model.Status == 5) progress = 100;
                    
                    var bgClass = Model.Status == 5 ? "bg-danger" : "bg-success";
                }
                <div class="progress" style="height: 25px;">
                    <div class="progress-bar progress-bar-striped progress-bar-animated @bgClass fw-bold" role="progressbar" style="width: @progress%;" aria-valuenow="@progress" aria-valuemin="0" aria-valuemax="100">
                        @progress%
                    </div>
                </div>
                <div class="d-flex justify-content-between mt-2 small text-muted fw-bold">
                    <span>Khởi tạo</span>
                    <span>Đã duyệt</span>
                    <span>Đang sửa</span>
                    <span>@(Model.Status == 5 ? "Đã hủy" : "Hoàn thành")</span>
                </div>
            </div>
        </div>

        <!-- NHÂN SỰ PHỤ TRÁCH -->
        @if (Model.Assignments != null && Model.Assignments.Any())
        {
            <h5 class="fw-bold mb-3 text-primary"><i class="bi bi-people-fill me-1"></i> Nhân sự phụ trách / Assigned Staff</h5>
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var assign in Model.Assignments)
                        {
                            if (assign.User != null)
                            {
                                <span class="badge bg-secondary fs-6"><i class="bi bi-person-badge me-1"></i> @assign.User.FirstName @assign.User.LastName</span>
                            }
                        }
                    </div>
                </div>
            </div>
        }

        <!-- PHẢN HỒI KẾT QUẢ TỪ QUẢN LÝ -->
        @{
            var finalNote = Model.MaintenanceNotes?.OrderByDescending(n => n.CreatedAt).FirstOrDefault(n => n.IsPublicResponse);
        }
        @if (finalNote != null)
        {
            <h5 class="fw-bold mb-3 text-success"><i class="bi bi-chat-dots-fill me-1"></i> Kết quả xử lý / Final Result</h5>
            <div class="card shadow-sm border-success border-2 mb-4">
                <div class="card-body bg-light">
                    <p class="mb-3 fs-5">@finalNote.NoteContent</p>
                    @if (!string.IsNullOrEmpty(finalNote.ImagePath))
                    {
                        <div>
                            <p class="text-muted small mb-1 fw-bold">Ảnh nghiệm thu / Result Image:</p>
                            <img src="@finalNote.ImagePath" class="img-fluid rounded border shadow-sm" style="max-height: 300px; object-fit: contain;" alt="Ảnh nghiệm thu" />
                        </div>
                    }
                    <div class="text-end text-muted small mt-2">
                        <i class="bi bi-clock me-1"></i> @finalNote.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                    </div>
                </div>
            </div>
        }
    </div>
</div>
