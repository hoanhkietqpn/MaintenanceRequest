<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - App Quản Lý Sự Cố</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <style>
        /* ─────────── Brand Colors ─────────── */
        .bg-vjaa   { background-color: #90c740 !important; }
        .text-vjaa { color: #90c740 !important; }
        .btn-vjaa  { background-color: #90c740; border-color: #90c740; color: white; }
        .btn-vjaa:hover { background-color: #7ba936; border-color: #7ba936; color: white; }
        .border-vjaa { border-color: #90c740 !important; }

        /* ─────────── Full-Screen Layout Fix ─────────── */
        html, body {
            height: 100%;
            min-height: 100vh;
            margin: 0;
            padding: 0;
        }

        body {
            display: flex;
            flex-direction: column;
        }

        #app-wrapper {
            display: flex;
            flex: 1 1 auto;
            min-height: 100vh;
            overflow: hidden;
        }

        /* ─────────── Sidebar ─────────── */
        #sidebar {
            width: 260px;
            min-width: 260px;
            min-height: 100vh;
            background: #343a40;
            transition: width 0.28s ease, min-width 0.28s ease, transform 0.28s ease;
            overflow: hidden;
            flex-shrink: 0;
            z-index: 1030;
        }

        #sidebar.collapsed {
            width: 0;
            min-width: 0;
        }

        #sidebar a {
            color: #adb5bd;
            text-decoration: none;
            display: block;
            padding: 10px 15px;
            white-space: nowrap;
        }

        #sidebar a:hover,
        #sidebar a.active {
            background: #495057;
            color: #fff;
        }

        /* ─────────── Main Content ─────────── */
        #main-content {
            flex: 1 1 auto;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            min-width: 0; /* prevents overflow */
            background: #f8f9fa;
        }

        #main-navbar {
            flex-shrink: 0;
        }

        #page-body {
            flex: 1 1 auto;
            overflow-y: auto;
            padding: 1.5rem;
        }

        /* ─────────── Sidebar Toggle Button ─────────── */
        #sidebar-toggle {
            border: none;
            background: transparent;
            color: #343a40;
            font-size: 1.4rem;
            padding: 0 0.5rem;
            line-height: 1;
            cursor: pointer;
            transition: color 0.2s;
        }

        #sidebar-toggle:hover { color: #90c740; }

        /* ─────────── Mobile: Overlay sidebar ─────────── */
        @@media (max-width: 991.98px) {
            #sidebar {
                position: fixed;
                top: 0;
                left: 0;
                height: 100vh;
                transform: translateX(0);
                z-index: 1050;
            }

            #sidebar.collapsed {
                transform: translateX(-100%);
                width: 260px;
                min-width: 260px;
            }

            #sidebar-overlay {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(0,0,0,0.45);
                z-index: 1040;
            }

            #sidebar-overlay.show { display: block; }

            #page-body {
                padding: 1rem;
            }
        }

        /* ─────────── Sticky sidebar (Details page) ─────────── */
        @@media (min-width: 992px) {
            .sticky-sidebar { position: sticky; top: 20px; }
        }
    </style>
</head>
<body>
    <!-- Sidebar Overlay (mobile backdrop) -->
    <div id="sidebar-overlay"></div>

    <div id="app-wrapper">

        <!-- ══ SIDEBAR ══ -->
        <div id="sidebar" class="text-white shadow-sm">
            <div class="p-3 bg-vjaa text-center fw-bold text-white d-flex align-items-center justify-content-between">
                <span><i class="bi bi-tools me-1"></i> BẢO TRÌ VIAA</span>
                <!-- Close button inside sidebar (mobile) -->
                <button id="sidebar-close" class="btn btn-sm btn-link text-white p-0 d-lg-none" title="Đóng menu">
                    <i class="bi bi-x-lg fs-5"></i>
                </button>
            </div>
            <div class="p-3">
                <p class="small text-uppercase mb-1 text-muted fw-bold">Xin chào,</p>
                <p class="text-white fw-bold mb-1" style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@User.Identity!.Name</p>
                <span class="badge bg-vjaa mb-3">@User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value</span>

                <h6 class="text-uppercase text-muted small mt-2 fw-bold">Menu</h6>
                <nav class="nav flex-column">
                    @if(User.IsInRole("Admin"))
                    {
                        <a href="/Admin/Index" class="mb-1 rounded"><i class="bi bi-house-door me-2"></i>Tổng quan Admin</a>
                        <a href="/Admin/Users" class="mb-1 rounded"><i class="bi bi-people me-2"></i>Quản lý Người dùng</a>
                    }
                    @if(User.IsInRole("QuanLyKyThuat") || User.IsInRole("Admin"))
                    {
                        <a href="/Manager/Index" class="mb-1 rounded"><i class="bi bi-person-gear me-2"></i>Trưởng nhóm Kỹ thuật</a>
                        <a href="/KPI/Index" class="mb-1 rounded"><i class="bi bi-bar-chart-line me-2"></i>Báo cáo KPI</a>
                    }
                    @if(User.IsInRole("NhanVienKyThuat") || User.IsInRole("QuanLyKyThuat"))
                    {
                        <a href="/Staff/Index" class="mb-1 rounded"><i class="bi bi-hammer me-2"></i>Nhiệm vụ của tôi</a>
                    }
                    <div class="mt-4 border-top border-secondary pt-3">
                        <form method="post" asp-controller="Auth" asp-action="Logout">
                            <button type="submit" class="btn btn-sm btn-outline-light w-100 fw-bold">
                                <i class="bi bi-box-arrow-right me-1"></i> Đăng xuất
                            </button>
                        </form>
                    </div>
                </nav>
            </div>
        </div>

        <!-- ══ MAIN CONTENT ══ -->
        <div id="main-content">
            <!-- Navbar -->
            <nav id="main-navbar" class="navbar navbar-light bg-white border-bottom shadow-sm px-3 px-md-4 py-2">
                <!-- Hamburger toggle -->
                <button id="sidebar-toggle" title="Đóng/Mở menu">
                    <i class="bi bi-list"></i>
                </button>
                <h5 class="mb-0 fw-bold text-dark ms-3 flex-grow-1">@ViewData["Title"]</h5>
                <!-- Optional: breadcrumb khu vực phải -->
            </nav>

            <!-- Page Body -->
            <div id="page-body">
                @RenderBody()
            </div>
        </div>

    </div><!-- /#app-wrapper -->

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        // ── SignalR ──
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")
            .build();

        connection.on("ReceiveMessage", function (user, message) {
            console.log(user + ": " + message);
        });

        connection.start().catch(err => console.error(err.toString()));

        // ── Sidebar Toggle ──
        const sidebar       = document.getElementById('sidebar');
        const overlay       = document.getElementById('sidebar-overlay');
        const toggleBtn     = document.getElementById('sidebar-toggle');
        const closeBtn      = document.getElementById('sidebar-close');
        const isMobile      = () => window.innerWidth < 992;

        // Khởi tạo trạng thái: mobile → collapsed mặc định
        function initSidebar() {
            if (isMobile()) {
                sidebar.classList.add('collapsed');
            } else {
                sidebar.classList.remove('collapsed');
            }
        }

        function openSidebar() {
            sidebar.classList.remove('collapsed');
            if (isMobile()) overlay.classList.add('show');
        }

        function closeSidebar() {
            sidebar.classList.add('collapsed');
            overlay.classList.remove('show');
        }

        toggleBtn.addEventListener('click', function () {
            sidebar.classList.contains('collapsed') ? openSidebar() : closeSidebar();
        });

        if (closeBtn) closeBtn.addEventListener('click', closeSidebar);
        overlay.addEventListener('click', closeSidebar);

        // Khi resize, tự động điều chỉnh
        window.addEventListener('resize', function () {
            if (!isMobile()) {
                overlay.classList.remove('show');
                // Trên desktop: giữ nguyên trạng thái collapsed/open từ user
            } else {
                overlay.classList.remove('show');
                if (!sidebar.classList.contains('collapsed')) closeSidebar();
            }
        });

        initSidebar();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
