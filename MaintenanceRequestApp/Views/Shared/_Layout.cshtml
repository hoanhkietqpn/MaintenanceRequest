<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - App Quản Lý Sự Cố</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        .bg-vjaa { background-color: #90c740 !important; }
        .text-vjaa { color: #90c740 !important; }
        .btn-vjaa { background-color: #90c740; border-color: #90c740; color: white; }
        .btn-vjaa:hover { background-color: #7ba936; border-color: #7ba936; color: white; }
        .sidebar { min-height: 100vh; background: #343a40; min-width: 250px; }
        .sidebar a { color: #adb5bd; text-decoration: none; display: block; padding: 10px 15px; }
        .sidebar a:hover, .sidebar a.active { background: #495057; color: #fff; }
    </style>
</head>
<body>
    <div class="d-flex border-0">
        <div class="sidebar text-white shadow-sm">
            <div class="p-3 bg-vjaa text-center fw-bold text-white">
                <i class="bi bi-tools fs-4 d-block mb-1"></i> BẢO TRÌ VIAA
            </div>
            <div class="p-3">
                <p class="small text-uppercase mb-2 text-muted fw-bold">Xin chào, @User.Identity.Name</p>
                <span class="badge bg-vjaa mb-4">@User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value</span>
                
                <h6 class="text-uppercase text-muted small mt-2 fw-bold">Menu</h6>
                <nav class="nav flex-column">
                    @if(User.IsInRole("Admin"))
                    {
                        <a href="/Admin/Index" class="mb-1 rounded"><i class="bi bi-house-door me-2"></i> Tổng quan Admin</a>
                    }
                    @if(User.IsInRole("QuanLyKyThuat") || User.IsInRole("Admin"))
                    {
                        <a href="/Manager/Index" class="mb-1 rounded"><i class="bi bi-person-gear me-2"></i> Trưởng nhóm Kỹ thuật</a>
                        <a href="/KPI/Index" class="mb-1 rounded"><i class="bi bi-bar-chart-line me-2"></i> Báo cáo KPI</a>
                    }
                    @if(User.IsInRole("NhanVienKyThuat"))
                    {
                        <a href="/Staff/Index" class="mb-1 rounded"><i class="bi bi-hammer me-2"></i> Nhiệm vụ của tôi</a>
                    }
                    <div class="mt-4 border-top border-secondary pt-3">
                        <form method="post" asp-controller="Auth" asp-action="Logout">
                            <button type="submit" class="btn btn-sm btn-outline-light w-100 fw-bold"><i class="bi bi-box-arrow-right me-1"></i> Đăng xuất</button>
                        </form>
                    </div>
                </nav>
            </div>
        </div>
        <div class="flex-grow-1 bg-light">
            <nav class="navbar navbar-light bg-white border-bottom shadow-sm px-4 py-3">
                <h5 class="mb-0 fw-bold text-dark">@ViewData["Title"]</h5>
            </nav>
            <div class="p-4" style="max-height: calc(100vh - 65px); overflow-y: auto;">
                @RenderBody()
            </div>
        </div>
    </div>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")
            .build();

        connection.on("ReceiveMessage", function (user, message) {
            // Optional: you can show a toast here
            // Alerting lightly
            console.log(user + ": " + message);
        });

        connection.start().catch(function (err) {
            return console.error(err.toString());
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
