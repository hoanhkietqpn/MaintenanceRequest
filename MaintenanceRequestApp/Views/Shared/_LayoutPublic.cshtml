<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VIAA Maintenance</title>
    <link rel="icon" type="image/png" href="~/images/icon.png" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        .bg-primary { background-color: #90c740 !important; }
        .text-primary { color: #90c740 !important; }
        .btn-primary { background-color: #90c740; border-color: #90c740; }
        .btn-primary:hover { background-color: #7ba936; border-color: #7ba936; }
        .btn-outline-primary { color: #90c740; border-color: #90c740; }
        .btn-outline-primary:hover { background-color: #90c740; border-color: #90c740; color: #fff;}
    </style>
</head>
<body class="bg-light pb-5">
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4 shadow">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/Request/Create">
                <i class="bi bi-tools me-2"></i> VIAA Maintenance
            </a>
            <a href="/Auth/Login" class="btn btn-sm btn-light fw-bold text-primary">Đăng nhập Quản trị</a>
        </div>
    </nav>
    <div class="container">
        @RenderBody()
    </div>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
