@model MaintenanceRequestApp.Models.ReminderSetting
@using Hangfire
@using Hangfire.Storage

@{
    ViewData["Title"] = "Cấu hình nhắc nhở phê duyệt";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Lấy thông tin job từ Hangfire API để hiển thị
    var connection = JobStorage.Current.GetConnection();
    var recurringJob = connection.GetRecurringJobs().FirstOrDefault(j => j.Id == "SendUnapprovedRequestsReminderJob");
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h2 class="fw-bold mb-4"><i class="bi bi-clock-history me-2 text-primary"></i>Cấu hình Nhắc nhở Tự động</h2>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="card shadow border-0 mb-4">
                <div class="card-header bg-white fw-bold">
                    Thiết lập Lịch (Cron) và Email
                </div>
                <div class="card-body">
                    <form asp-action="Update" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Chuỗi thời gian (Cron Expression)</label>
                            <input asp-for="CronExpression" class="form-control font-monospace" placeholder="VD: 0 10,15,21 * * *" required />
                            <small class="text-muted">Định dạng Cron (Phút Giờ Ngày Tháng Thứ). Ví dụ: <code>0 10,15,21 * * *</code> nghĩa là chạy vào lúc 10:00, 15:00 và 21:00 mỗi ngày.</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Danh sách Email nhận thông báo</label>
                            <textarea asp-for="TargetEmails" class="form-control" rows="3" placeholder="admin1@example.com, admin2@example.com" required></textarea>
                            <small class="text-muted">Các địa chỉ email ngăn cách nhau bằng dấu phẩy (,)</small>
                        </div>

                        <div class="form-check form-switch mb-4">
                            <input class="form-check-input" type="checkbox" role="switch" id="IsActive" name="IsActive" value="true" @(Model.IsActive ? "checked" : "")>
                            <label class="form-check-label fw-bold text-dark" for="IsActive">Kích hoạt gửi email tự động</label>
                            <!-- Hidden field to handle unchecked state -->
                            <input type="hidden" name="IsActive" value="false" />
                        </div>

                        <button type="submit" class="btn btn-primary w-100 fw-bold">
                            <i class="bi bi-save me-2"></i>Lưu Cấu Hình
                        </button>
                    </form>
                </div>
            </div>

            <div class="card shadow border-0 border-start border-info border-4">
                <div class="card-header bg-white fw-bold d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-activity me-2 text-info"></i>Trạng thái Job hiện tại (Hangfire)</span>
                    <a href="/hangfire" target="_blank" class="btn btn-sm btn-outline-info">Mở Hangfire Dashboard</a>
                </div>
                <div class="card-body">
                    @if (recurringJob != null)
                    {
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <strong>Trạng thái:</strong>
                                @if (Model.IsActive)
                                {
                                    <span class="badge bg-success rounded-pill">Đang hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary rounded-pill">Đã tạm dừng</span>
                                }
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <strong>Lịch chạy (Cron):</strong>
                                <span class="font-monospace">@recurringJob.Cron</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <strong>Lần chạy cuối (Last Execution):</strong>
                                <span>@(recurringJob.LastExecution?.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss") ?? "Chưa chạy lần nào")</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <strong>Lần chạy tiếp theo (Next Execution):</strong>
                                <span>@(recurringJob.NextExecution?.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss") ?? "Không xác định")</span>
                            </li>
                        </ul>
                    }
                    else
                    {
                        <div class="alert alert-warning mb-0">
                            <i class="bi bi-exclamation-triangle me-2"></i>Chưa có Job nào được đăng ký trong hệ thống Hangfire. Hãy lưu cấu hình ở trên để tạo Job.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
